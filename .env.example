# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:6001
NEXT_PUBLIC_IDENTITY_URL=http://localhost:5000
NEXT_PUBLIC_IDENTITY_SERVER_URL=http://localhost:5000
NEXT_PUBLIC_WS_URL=ws://localhost:6001

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here
AUTH_SECRET=your-secret-key-here

# OpenID Connect Configuration
NEXT_PUBLIC_CLIENT_ID=stemify-web-client
NEXT_PUBLIC_SCOPES=openid profile email offline_access roles

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Feature Flags
NEXT_PUBLIC_ENABLE_3D_EMULATOR=true
NEXT_PUBLIC_ENABLE_AI_FEATURES=true
