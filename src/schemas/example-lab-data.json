  "activities": [
    {
      "id": "activity_1",
      "name": "Basic T-Joint Assembly",
      "description": "Learn how to connect straws using a T-joint connector",
      "difficulty": "beginner",
      "estimatedTime": 300,
      "objectives": [
        "Understand connector types",
        "Practice precise alignment",
        "Learn connection validation"
      ],
      "steps": [
        {
          "id": "step_1",
          "order": 1,
          "title": "Identify Components",
          "description": "Locate the orange straw and green T-connector",
          "actionIds": [],
          "expectedResult": "Components are visually identified",
          "hints": ["Look for the orange colored straw", "Find the T-shaped green connector"]
        },
        {
          "id": "step_2",
          "order": 2,
          "title": "Position Straw",
          "description": "Move the straw close to the connector",
          "actionIds": ["action_1"],
          "expectedResult": "Straw is positioned near the connector port",
          "hints": ["Drag the straw slowly", "Watch for snap-to guides"],
          "validation": {
            "type": "position",
            "criteria": {
              "maxDistance": 2.0,
              "targetPosition": { "x": 15, "y": 0, "z": 0 }
            }
          }
        },
        {
          "id": "step_3",
          "order": 3,
          "title": "Make Connection",
          "description": "Align and connect the straw to the connector port",
          "actionIds": ["action_2"],
          "expectedResult": "Straw is firmly connected to connector",
          "hints": ["Look for the connection highlight", "Ensure proper alignment"],
          "validation": {
            "type": "connection",
            "criteria": {
              "jointId": "joint_1",
              "connected": true
            }
          }
        },
        {
          "id": "step_4",
          "order": 4,
          "title": "Verify Connection",
          "description": "Observe the connection highlighting",
          "actionIds": ["action_3"],
          "expectedResult": "Connection is highlighted and secure",
          "hints": ["Watch for the golden highlight effect"]
        }
      ],
      "playbackControls": {
        "allowRewind": true,
        "allowPause": true,
        "allowSkip": false,
        "speed": 1.0
      }
    }
  ],
  
